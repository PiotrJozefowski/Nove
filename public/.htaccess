# Nove — hosting statyczny (cyber-folks). Bez node/proxy.
DirectoryIndex index.html
ErrorDocument 404 /404.html

RewriteEngine On

# Ukryj pliki danych realizacji (Title/Content/Year/Location.txt)
RewriteRule ^realizacje/[^/]+/(Title|Content|Year|Location)\.txt$ - [F,L]

# Czyste adresy stron (bez .html)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^realizacje/?$ realizacje.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ogrodzenia/?$ ogrodzenia.html [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^kontakt/?$ kontakt.html [L]

# Świeży HTML, długi cache dla zasobów wersjonowanych
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  <FilesMatch "\.(css|js|jpg|jpeg|png|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
